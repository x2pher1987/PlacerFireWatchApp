rules_version = '2';

// Fire report photo uploads and responder application documents both
// require the uploading account to be signed in, capped at 10MB, and
// must actually be images. Neither has a client-side read feature —
// the fire report dashboard and admin approval screen both use
// getDownloadURL() links already saved in Firestore, which embed an
// access token that bypasses these rules by design, so "read: false"
// here doesn't block their actual, legitimate use.
service firebase.storage {
  match /b/{bucket}/o {
    match /fire_report_photos/{fileName} {
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow read: if false;
    }

    match /responder_applications/{uid}/{fileName} {
      allow write: if request.auth != null && request.auth.uid == uid
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow read: if false;
    }
  }
}
