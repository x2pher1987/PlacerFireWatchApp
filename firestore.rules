rules_version = '2';

// Every account has a users/{uid} doc holding its role. Anyone can
// self-register (role forced to "citizen" at creation); becoming a
// responder or admin means an out-of-band edit to that same doc by the
// project admin via the Firebase console — see the README's "Create
// responder accounts" section. Fire report writes require the signed-in
// UID to match the report's userId; reads/status-updates require an
// *approved* responder (or, later, an admin).
service cloud.firestore {
  match /databases/{database}/documents {

    function currentUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isApprovedResponder() {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && currentUserDoc().role == 'responder'
        && currentUserDoc().responderStatus == 'approved';
    }

    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create: if request.auth != null && request.auth.uid == uid
        && request.resource.data.role == 'citizen'
        && request.resource.data.keys().hasOnly(
             ['fullName', 'email', 'role', 'responderStatus', 'suspended', 'createdAt']
           );
      allow update: if false;
      allow delete: if false;
    }

    match /fire_reports/{reportId} {
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == "Pending"
        && request.resource.data.keys().hasOnly(
             ['latitude', 'longitude', 'timestamp', 'userId', 'photoUrl', 'note', 'status', 'barangay']
           );
      allow read: if isApprovedResponder();
      allow update: if isApprovedResponder()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
        && request.resource.data.status in
             ['Accepted', 'Responding', 'Arrived', 'Fire Out', 'False Alarm'];
      allow delete: if false;
    }
  }
}
