rules_version = '2';

// Every account has a users/{uid} doc holding its role. Anyone can
// self-register (role forced to "citizen" at creation). Becoming a
// responder or admin normally happens through the in-app application +
// admin-approval flow (responder_applications/{uid} below); admins can
// also promote/suspend accounts directly by editing users/{uid} in the
// Firebase console. Fire report writes require the signed-in UID to
// match the report's userId; reads/status-updates require an *approved*
// responder or an admin.
service cloud.firestore {
  match /databases/{database}/documents {

    function currentUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isApprovedResponder() {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && currentUserDoc().role == 'responder'
        && currentUserDoc().responderStatus == 'approved';
    }

    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && currentUserDoc().role == 'admin';
    }

    match /users/{uid} {
      allow read: if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow create: if request.auth != null && request.auth.uid == uid
        && request.resource.data.role == 'citizen'
        && request.resource.data.keys().hasOnly(
             ['fullName', 'email', 'role', 'responderStatus', 'suspended', 'createdAt']
           );
      // Only an admin can change role/responderStatus/suspended, and only
      // those three fields — never fullName/email, and never self-granted.
      allow update: if isAdmin()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(
             ['role', 'responderStatus', 'suspended']
           );
      allow delete: if false;
    }

    // One application per account, keyed by the applicant's own UID.
    // Applicants can create/update their own application while it's still
    // pending (e.g. to fix a mistake before an admin reviews it); once an
    // admin approves/rejects, only the status field itself can move, and
    // only an admin can move it.
    match /responder_applications/{uid} {
      allow read: if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow create: if request.auth != null && request.auth.uid == uid
        && request.resource.data.status == 'pending';
      allow update: if (request.auth != null && request.auth.uid == uid
             && resource.data.status == 'pending' && request.resource.data.status == 'pending')
          || (isAdmin() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']));
      allow delete: if false;
    }

    match /fire_reports/{reportId} {
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == "Pending"
        && request.resource.data.keys().hasOnly(
             ['latitude', 'longitude', 'timestamp', 'userId', 'photoUrl', 'note', 'status', 'barangay']
           );
      allow read: if isApprovedResponder() || isAdmin();
      allow update: if (isApprovedResponder() || isAdmin())
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
        && request.resource.data.status in
             ['Accepted', 'Responding', 'Arrived', 'Fire Out', 'False Alarm'];
      allow delete: if false;
    }
  }
}
