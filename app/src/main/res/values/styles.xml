<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!--
        Section 14 UI redesign: rounded, card-based dark theme. These
        ShapeAppearance overrides are the cross-cutting mechanism — Material
        Components' Button/Chip/TextField/Dialog styles all resolve their
        corners through ?attr/shapeAppearance*Component at runtime, so
        setting these three in Theme.PlacerFireWatch reshapes every
        MaterialButton, MaterialCardView, and Chip in the app without
        editing each layout individually.
    -->
    <style name="ShapeAppearance.PlacerFireWatch.SmallComponent" parent="ShapeAppearance.MaterialComponents.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>

    <style name="ShapeAppearance.PlacerFireWatch.MediumComponent" parent="ShapeAppearance.MaterialComponents.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>

    <style name="ShapeAppearance.PlacerFireWatch.LargeComponent" parent="ShapeAppearance.MaterialComponents.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">20dp</item>
    </style>

    <style name="Widget.PlacerFireWatch.CardView" parent="Widget.MaterialComponents.CardView">
        <item name="cardElevation">3dp</item>
        <item name="cardBackgroundColor">@color/surface_dark</item>
        <item name="rippleColor">@color/fire_orange</item>
    </style>

</resources>
